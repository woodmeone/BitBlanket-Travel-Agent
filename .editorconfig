root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{py,pyi}]
indent_style = space
indent_size = 4

[*.{ts,tsx,js,jsx,json,jsonl,yml,yaml,css,scss,html}]
indent_style = space
indent_size = 2

[*.{ps1,psm1,psd1}]
indent_style = space
indent_size = 2
end_of_line = crlf
