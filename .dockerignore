# =============================================================================
# Docker Ignore File
# =============================================================================
# 减少 Docker 镜像大小，排除不必要的文件

# =============================================================================
# Git
# =============================================================================
.git
.gitignore

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
*.egg-info/
dist/
build/
*.egg

# =============================================================================
# 测试和开发文件
# =============================================================================
tests/
test_*.py
*_test.py
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# =============================================================================
# IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# 文档
# =============================================================================
docs/
learn_docs/
*.md
LICENSE
CHANGELOG.md

# =============================================================================
# 配置文件（敏感）
# =============================================================================
.env
.env.local
.env.*.local
backend/config/llm_config.yaml

# =============================================================================
# Node.js (前端)
# =============================================================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.cache/

# =============================================================================
# 日志
# =============================================================================
logs/
*.log

# =============================================================================
# Docker
# =============================================================================
.dockerignore
docker-compose.override.yml

# =============================================================================
# Claude Code
# =============================================================================
.claude/
