# =============================================================================
# ShuaiTravelAgent 环境变量配置示例
# =============================================================================
# 复制此文件为 .env 并填入实际值
# =============================================================================

# =============================================================================
# LLM API 配置 (至少配置一个)
# =============================================================================

# MiniMax API (推荐)
MINIMAX_API_KEY=sk-cp-your-api-key-here

# OpenAI API (可选)
# OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic Claude API (可选)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# =============================================================================
# 服务配置
# =============================================================================

# 环境
ENVIRONMENT=dev

# CORS 允许的源 (逗号分隔)
CORS_ORIGINS=http://localhost:33001
