# =============================================================================
# ShuaiTravelAgent Environment Variables Example
# =============================================================================
# Copy this file to `.env` and fill in real values.
# =============================================================================

# =============================================================================
# LLM Configuration (at least configure one provider)
# =============================================================================

# MiniMax (Anthropic-compatible)
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_AUTH_TOKEN=sk-cp-your-minimax-token
ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M2.5

# Optional OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key

# Optional Anthropic official
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# =============================================================================
# Service Configuration
# =============================================================================
ENVIRONMENT=dev
SHUAI_WEB_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:33001
SHUAI_WEB_PORT=38000
SHUAI_FRONTEND_PORT=33001
SHUAI_REQUEST_TIMEOUT_SECONDS=30
SHUAI_RATE_LIMIT_MAX_REQUESTS=100
SHUAI_RATE_LIMIT_WINDOW_SECONDS=60
SHUAI_METRICS_ENABLED=true
SHUAI_METRICS_PATH=/api/metrics
SHUAI_STRUCTURED_LOGGING=true
SHUAI_FAIL_FAST_STARTUP_VALIDATION=false
