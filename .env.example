# =============================================================================
# ShuaiTravelAgent Environment Variables Example
# =============================================================================
# Copy this file to `.env` and fill in real values.
# =============================================================================

# =============================================================================
# LLM Configuration (at least configure one provider)
# =============================================================================

# MiniMax (Anthropic-compatible)
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_AUTH_TOKEN=sk-cp-your-minimax-token
ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M2.5

# Optional OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key

# Optional Anthropic official
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# =============================================================================
# Service Configuration
# =============================================================================
ENVIRONMENT=dev
CORS_ORIGINS=http://localhost:33001
