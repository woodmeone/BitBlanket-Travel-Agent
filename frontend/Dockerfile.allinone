# Build stage
FROM node:20-alpine AS builder
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Build Python backend
COPY ../web /app/web
COPY ../agent /app/agent
COPY ../config /app/config
COPY ../requirements.txt /app/
WORKDIR /app
RUN pip install --no-cache-dir -r requirements.txt
WORKDIR /app/frontend

# Expose ports
EXPOSE 3000 8000

# Start both services
CMD ["sh", "-c", "npm run dev & python -m uvicorn shuai_web.main:app --host 0.0.0.0 --port 38000 --app-dir /app/web"]
